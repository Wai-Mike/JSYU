<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files/directories directly (required for /storage/* and Vite assets)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Otherwise, send the request to Laravel.
    RewriteRule ^ index.php [L]
</IfModule>
